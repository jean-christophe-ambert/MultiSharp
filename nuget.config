<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <!-- Étend la config NuGet globale pour ajouter les packages spécifiques à ce projet -->
  <packageSourceMapping>
    <!-- Wildcard pour couvrir toutes les dépendances transitives des packages VS SDK,
         Roslyn Testing, xUnit, etc. qui ne sont pas dans la config NuGet globale -->
    <packageSource key="nuget.org">
      <package pattern="*" />
    </packageSource>
  </packageSourceMapping>
</configuration>
